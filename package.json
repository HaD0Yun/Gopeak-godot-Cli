{
  "name": "gopeak-cli",
  "version": "1.0.0",
  "description": "CLI-first Godot automation with optional MCP integration via 4 meta-tools",
  "type": "module",
  "main": "dist/mcp/index.js",
  "bin": {
    "gopeak-cli": "dist/cli.js"
  },
  "files": [
    "dist/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "postinstall": "node -e \"console.log('[gopeak-cli] Optional shell hooks are not installed automatically. Run \\\"gopeak-cli setup\\\" to enable them.')\"",
    "prepack": "npm run build",
    "test": "node dist/daemon/request-loop.test.js"
  },
  "keywords": [
    "godot",
    "cli",
    "mcp",
    "game-engine",
    "ai",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "axios": "^1.7.9",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "license": "MIT"
}
